# Instagram Graph API（最新投稿を表示する場合）
# 取得手順: https://developers.facebook.com/docs/instagram-platform
# - Facebook アプリ作成 → Instagram Graph API を追加
# - Instagram ビジネス/クリエイターアカウントを Facebook ページに接続
# - 長期トークンと IG User ID を取得し、以下に設定
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# microCMS（お知らせ一覧・詳細）
# 管理画面: https://108teaworks.microcms.io/ → API キーは各 API の「APIキー」から取得
MICROCMS_SERVICE_DOMAIN=108teaworks
MICROCMS_API_KEY=

# ---------- メール送信（Brevo SMTP） ----------
# 手順: next-app/docs/BREVO-SETUP.md を参照
# 送信のみ変更。受信（IMAP/POP3）はそのまま。
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 送信元（Brevo で認証した @108teaworks.com のアドレス）
ORDER_FROM=info@108teaworks.com
INQUERY_FROM=info@108teaworks.com
CLIENT_MAIL_FROM=info@108teaworks.com

# 送信元の表示名（メールクライアントで「藤八茶寮 <info@...>」と表示される）
MAIL_FROM_NAME=藤八茶寮

# 管理者あて（注文・お問い合わせ通知の宛先）
ORDER_ADMIN_TO=info@108teaworks.com
INQUERY_TO=info@108teaworks.com
