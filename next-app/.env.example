# Instagram Graph API（最新投稿を表示する場合）
# 取得手順: https://developers.facebook.com/docs/instagram-platform
# - Facebook アプリ作成 → Instagram Graph API を追加
# - Instagram ビジネス/クリエイターアカウントを Facebook ページに接続
# - 長期トークンと IG User ID を取得し、以下に設定
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# microCMS（お知らせ一覧・詳細）
# 管理画面: https://108teaworks.microcms.io/ → API キーは各 API の「APIキー」から取得
MICROCMS_SERVICE_DOMAIN=108teaworks
MICROCMS_API_KEY=
